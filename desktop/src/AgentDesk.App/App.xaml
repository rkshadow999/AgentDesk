<Application
    x:Class="AgentDesk.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <!--
                  AgentDesk web surfaces are dark-first. Keep Light dictionary keys
                  on the same dark palette so system light mode cannot flash white
                  chrome around WebView2 content.
                -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AgentDeskChromeBrush" Color="#1B1D1C" />
                    <SolidColorBrush x:Key="AgentDeskStatusBrush" Color="#151716" />
                    <SolidColorBrush x:Key="AgentDeskSurfaceBrush" Color="#181A19" />
                    <SolidColorBrush x:Key="AgentDeskDividerBrush" Color="#343936" />
                    <SolidColorBrush x:Key="AgentDeskMutedBrush" Color="#9BA29E" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AgentDeskChromeBrush" Color="#1B1D1C" />
                    <SolidColorBrush x:Key="AgentDeskStatusBrush" Color="#151716" />
                    <SolidColorBrush x:Key="AgentDeskSurfaceBrush" Color="#181A19" />
                    <SolidColorBrush x:Key="AgentDeskDividerBrush" Color="#343936" />
                    <SolidColorBrush x:Key="AgentDeskMutedBrush" Color="#9BA29E" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="AgentDeskReadyBrush" Color="#0F7B0F" />
            <SolidColorBrush x:Key="AgentDeskWaitingBrush" Color="#9D5D00" />
            <SolidColorBrush x:Key="AgentDeskErrorBrush" Color="#C42B1C" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
