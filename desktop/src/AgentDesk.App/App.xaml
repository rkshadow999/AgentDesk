<Application
    x:Class="AgentDesk.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AgentDeskChromeBrush" Color="#F7F7F7" />
                    <SolidColorBrush x:Key="AgentDeskStatusBrush" Color="#FAFAFA" />
                    <SolidColorBrush x:Key="AgentDeskDividerBrush" Color="#1F000000" />
                    <SolidColorBrush x:Key="AgentDeskMutedBrush" Color="#7A727272" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AgentDeskChromeBrush" Color="#202020" />
                    <SolidColorBrush x:Key="AgentDeskStatusBrush" Color="#1B1B1B" />
                    <SolidColorBrush x:Key="AgentDeskDividerBrush" Color="#2EFFFFFF" />
                    <SolidColorBrush x:Key="AgentDeskMutedBrush" Color="#A6A6A6" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="AgentDeskReadyBrush" Color="#0F7B0F" />
            <SolidColorBrush x:Key="AgentDeskWaitingBrush" Color="#9D5D00" />
            <SolidColorBrush x:Key="AgentDeskErrorBrush" Color="#C42B1C" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
