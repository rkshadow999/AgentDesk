<Window
    x:Class="AgentDesk.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="AgentDesk">

    <Grid
        x:Name="RootGrid"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Padding="16,0,148,0"
            Background="{ThemeResource AgentDeskChromeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                Width="24"
                Height="24"
                VerticalAlignment="Center"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="5">
                <FontIcon
                    FontSize="13"
                    Foreground="White"
                    Glyph="&#xE943;" />
            </Border>

            <StackPanel
                Grid.Column="1"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <TextBlock
                    x:Uid="AppTitle"
                    FontSize="13"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />
                <TextBlock
                    x:Uid="AppEdition"
                    FontSize="12"
                    Foreground="{ThemeResource AgentDeskMutedBrush}"
                    VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="7">
                <Ellipse
                    x:Name="TitleStatusDot"
                    Width="7"
                    Height="7"
                    Fill="{ThemeResource AgentDeskWaitingBrush}" />
                <TextBlock
                    x:Name="TitleStatusText"
                    x:Uid="LoadingStatus"
                    FontSize="12"
                    Foreground="{ThemeResource AgentDeskMutedBrush}"
                    VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <WebView2
                x:Name="WorkbenchWebView"
                Grid.Column="0"
                DefaultBackgroundColor="Transparent" />

            <Border
                Grid.Column="1"
                Background="{ThemeResource AgentDeskDividerBrush}" />

            <WebView2
                x:Name="InspectorWebView"
                Grid.Column="2"
                DefaultBackgroundColor="Transparent" />

            <Grid
                x:Name="LoadingPanel"
                Grid.ColumnSpan="3"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <ProgressRing
                        Width="28"
                        Height="28"
                        IsActive="True" />
                    <TextBlock
                        x:Uid="LoadingWorkbench"
                        Foreground="{ThemeResource AgentDeskMutedBrush}"
                        TextAlignment="Center" />
                </StackPanel>
            </Grid>

            <Grid
                x:Name="ErrorPanel"
                Grid.ColumnSpan="3"
                Padding="32"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                Visibility="Collapsed">
                <StackPanel
                    MaxWidth="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">
                    <FontIcon
                        FontSize="30"
                        Foreground="{ThemeResource AgentDeskErrorBrush}"
                        Glyph="&#xEA39;" />
                    <TextBlock
                        x:Uid="WorkbenchUnavailable"
                        FontSize="20"
                        FontWeight="SemiBold"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="ErrorMessageText"
                        Foreground="{ThemeResource AgentDeskMutedBrush}"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                    <Button
                        x:Name="ReloadButton"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Center"
                        Click="ReloadButton_Click">
                        <FontIcon Glyph="&#xE72C;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Border
            Grid.Row="2"
            Padding="12,0"
            Background="{ThemeResource AgentDeskStatusBrush}"
            BorderBrush="{ThemeResource AgentDeskDividerBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="7">
                    <Ellipse
                        x:Name="StatusDot"
                        Width="6"
                        Height="6"
                        Fill="{ThemeResource AgentDeskWaitingBrush}" />
                    <TextBlock
                        x:Name="EngineStatusText"
                        x:Uid="EngineNotConnected"
                        FontSize="11"
                        Foreground="{ThemeResource AgentDeskMutedBrush}" />
                </StackPanel>

                <TextBlock
                    x:Name="WorkspaceStatusText"
                    Grid.Column="1"
                    Margin="20,0"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{ThemeResource AgentDeskMutedBrush}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis" />

                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="6">
                    <FontIcon
                        FontSize="11"
                        Foreground="{ThemeResource AgentDeskMutedBrush}"
                        Glyph="&#xE72E;" />
                    <TextBlock
                        x:Uid="NativeProtected"
                        FontSize="11"
                        Foreground="{ThemeResource AgentDeskMutedBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
